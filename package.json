{
  "name": "blitztext-app",
  "version": "0.4.0",
  "description": "Windows-Neuschrieb der Blitztext Speech-to-Text App (Electron + React + TypeScript)",
  "private": true,
  "author": "edo-dzell",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/renderer/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:helper": "bash native/win-paste/build.sh",
    "package:win": "npm run build:helper && electron-vite build && electron-builder --win && node scripts/retain-releases.mjs",
    "package:exe": "npm run build:helper && electron-vite build && electron-builder --win portable",
    "version:jump": "npm version minor --no-git-tag-version",
    "version:improve": "npm version patch --no-git-tag-version"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
